#!/usr/bin/env bun

import { execSync } from "node:child_process";

import chalk from "chalk";

import * as bundler from "../src/bundler";
import * as server from "../src/server";
import { ROOT, NAME, VERSION } from "../src/utils";

const build = () => {
  bundler.build();
  console.log(`
    ${chalk.cyan(NAME)} ${chalk.green(`v${VERSION}`)} ${chalk.gray("- BUILD")}
    ${chalk.gray("Built sources to")} ./dist
    ${chalk.gray("To preview, use")} bun run preview
  `);
};

const buildDesktop = () => {
  bundler.build(`${ROOT}/app/desktop/dist`);
  execSync(`bun run package`, {
    stdio: "inherit",
    cwd: `${ROOT}/app/desktop`,
  });
  console.log(`
    ${chalk.cyan(NAME)} ${chalk.green(`v${VERSION}`)} ${chalk.gray("- BUILD DESKTOP")}
    ${chalk.gray("Built app to")} ./app/desktop/out
  `);
};

const dev = () => {
  const port = server.dev();
  console.log(`
    ${chalk.cyan(NAME)} ${chalk.green(`v${VERSION}`)} ${chalk.gray("- DEV")}
    ${chalk.gray("at")} http://localhost:${port}/
  `);
};

const devDesktop = () => {
  const port = server.dev();
  console.log(`
    ${chalk.cyan(NAME)} ${chalk.green(`v${VERSION}`)} ${chalk.gray("- DEV DESKTOP")}
    ${chalk.gray("Press CTRL + C to stop ...")}
  `);
  execSync(`URL=http://localhost:${port} bun start`, {
    stdio: "inherit",
    cwd: `${ROOT}/app/desktop`,
  });
  process.exit(0);
};

const preview = () => {
  const port = server.preview();
  console.log(`
    ${chalk.cyan(NAME)} ${chalk.green(`v${VERSION}`)} ${chalk.gray("- PREVIEW")}
    ${chalk.gray("at")} http://localhost:${port}/
  `);
};

(() => {
  const index = process.argv.indexOf(process.argv[1]);
  const [cmd] = process.argv.slice(index + 1);

  switch (cmd || "dev") {
    case "build":
      build();
      break;
    case "build:desktop":
      buildDesktop();
      break;
    case "dev":
      dev();
      break;
    case "dev:desktop":
      devDesktop();
      break;
    case "preview":
      preview();
      break;
    default:
      console.log(`Unknown command: ${cmd}`);
  }
})();
